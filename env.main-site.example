# Asper Beauty Shop — Main site environment variables
# Copy to:
#   - Lovable project (Settings → Environment variables)
#   - understand-project/.env (for local dev; keep .env in .gitignore)
# Do NOT commit real keys. Use this file as a template only.

# ========== Supabase (Brain / Beauty Assistant) ==========
# NOTE: Use qqceibvalkoytafynwoc (correct project) — NOT old ID rgehleqcubtmcwyipyvi
VITE_SUPABASE_PROJECT_ID=qqceibvalkoytafynwoc
VITE_SUPABASE_URL=https://qqceibvalkoytafynwoc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# ========== Shopify (Storefront — 5000+ SKUs) ==========
VITE_SHOPIFY_STORE_DOMAIN=lovable-project-milns.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=
VITE_SHOPIFY_API_VERSION=2025-07

# ========== Main URL ==========
VITE_SITE_URL=https://asperbeautyshop-com.lovable.app/
VITE_LOVABLE_URL=asperbeautyshop-com.lovable.app

# ========== Lovable Webhook (GitHub Actions sync — optional) ==========
# Used by .github/workflows/deploy-health-check.yml,
#         .github/workflows/sync-file-changes-to-lovable.yml, and
#         .github/workflows/sync-issues-prs-to-lovable.yml
# How to obtain:
#   1. Open https://lovable.dev/projects/657fb572-13a5-4a3e-bac9-184d39fdf7e6
#   2. Go to Settings → Integrations → GitHub → Webhook URL
#   3. Copy the webhook URL and paste it below (local) or add it as a
#      GitHub Actions secret named LOVABLE_WEBHOOK_URL
#      (repo → Settings → Secrets and variables → Actions → New repository secret)
# Leave empty to disable webhook sync (workflows will skip gracefully).
LOVABLE_WEBHOOK_URL=

# ========== Sync script (local / CI; NOT for Lovable) ==========
# Get token from: Shopify Admin → Settings → Apps → Develop apps
#   → Create app → Configure Admin API scopes:
#     write_products, read_products, write_inventory, read_inventory
#   → Install app → reveal token
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=lovable-project-milns.myshopify.com
CSV_PATH=./data/shopify-import-2.csv
