# Asper Beauty Shop — Environment Variables
# Copy to .env (keep .env in .gitignore — NEVER commit real keys)
#
# Two contexts:
#   1. Frontend (Lovable / Vite) — VITE_* prefixed, safe to expose client-side
#   2. Sync script (local/CI only) — server-side, NEVER in frontend

# ========== Supabase (Brain / Beauty Assistant) ==========
VITE_SUPABASE_PROJECT_ID=qqceibvalkoytafynwoc
VITE_SUPABASE_URL=https://qqceibvalkoytafynwoc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# ========== Shopify Storefront (Frontend — read-only) ==========
VITE_SHOPIFY_STORE_DOMAIN=lovable-project-milns.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=
VITE_SHOPIFY_API_VERSION=2025-07

# ========== Site URLs ==========
VITE_SITE_URL=https://asperbeautyshop-com.lovable.app/
VITE_LOVABLE_URL=asperbeautyshop-com.lovable.app

# ========== Sync Script (local / CI only — DO NOT set in Lovable) ==========
# Get token from: Shopify Admin > Settings > Apps > Develop apps
# Required scopes: write_products, read_products, write_inventory, read_inventory
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=lovable-project-milns.myshopify.com
CSV_PATH=./data/shopify-import-2.csv

# ========== Usage ==========
# Dry run (no API calls):   npm run sync:dry-run
# Full sync:                npm run sync
# Sync + publish products:  npm run sync:publish
# Limit to N products:      npx tsx scripts/sync-shopify-catalog.ts --limit 10
